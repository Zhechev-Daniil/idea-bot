# ============================================================
# СКОПИРУЙ ЭТОТ ФАЙЛ В .env И ЗАПОЛНИ ЗНАЧЕНИЯ
# cp .env.example .env
# НИКОГДА не коммить .env в git!
# ============================================================

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# --- Anthropic Claude API ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Модель для генерации гипотез (Sonnet — быстро и дёшево)
CLAUDE_MODEL=claude-sonnet-4-6
# Модель для чата на дашборде (Opus — глубже и точнее)
CLAUDE_OPUS_MODEL=claude-opus-4-6

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# --- OpenAI (для Whisper — транскрипция голоса и видео) ---
# Можно оставить пустым, если не нужна транскрипция аудио
OPENAI_API_KEY=your_openai_api_key_here

# --- Дашборд ---
# URL после деплоя на GitHub Pages
DASHBOARD_URL=https://yourusername.github.io/idea-bot

# --- Настройки бота ---
# Твой Telegram user_id (бот будет отвечать только тебе)
# Узнать можно у @userinfobot
ALLOWED_USER_ID=your_telegram_user_id

# Контекст для гипотез: startup | personal_brand | both
HYPOTHESIS_CONTEXT=both
